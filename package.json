{
  "name": "sf-webdriverio",
  "version": "1.0.0",
  "description": "WebDriverIO TypeScript test automation skeleton — web UI & REST API, Page Object Model, multi-env dotenv, Allure reporting",
  "author": "",
  "license": "MIT",
  "scripts": {
    "test": "wdio run src/config/wdio.base.conf.ts",
    "test:chrome": "BROWSER=chrome wdio run src/config/wdio.chrome.conf.ts",
    "test:firefox": "BROWSER=firefox wdio run src/config/wdio.firefox.conf.ts",
    "test:ui": "wdio run src/config/wdio.base.conf.ts --suite ui",
    "test:api": "wdio run src/config/wdio.base.conf.ts --suite api",
    "test:env:dev": "ENV=dev wdio run src/config/wdio.base.conf.ts",
    "test:env:staging": "ENV=staging wdio run src/config/wdio.base.conf.ts",
    "report:generate": "allure generate allure-results --clean -o allure-report",
    "report:open": "allure open allure-report"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@wdio/allure-reporter": "^9.0.5",
    "@wdio/cli": "^9.0.5",
    "@wdio/globals": "^9.0.5",
    "@wdio/local-runner": "^9.0.5",
    "@wdio/mocha-framework": "^9.0.5",
    "@wdio/spec-reporter": "^9.0.5",
    "allure-commandline": "^2.29.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
