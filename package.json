{
  "name": "sf-webdriverio",
  "version": "1.0.0",
  "description": "WebDriverIO TypeScript test automation skeleton — web UI & REST API, Page Object Model, multi-env dotenv, Allure reporting",
  "author": "",
  "license": "MIT",
  "scripts": {
    "test": "wdio run wdio.conf.ts",
    "test:web": "wdio run wdio.conf.ts --spec tests/web/",
    "test:api": "wdio run wdio.conf.ts --spec tests/api/",
    "test:sample": "wdio run wdio.conf.ts --spec tests/web/ --spec tests/api/",
    "test:dev": "TEST_ENV=dev wdio run wdio.conf.ts",
    "test:staging": "TEST_ENV=staging wdio run wdio.conf.ts",
    "test:prod": "TEST_ENV=prod wdio run wdio.conf.ts",
    "test:headed": "HEADLESS=false wdio run wdio.conf.ts",
    "test:debug": "node --inspect-brk ./node_modules/.bin/wdio run wdio.conf.ts",
    "test:report": "npx allure generate allure-results -o allure-report --clean && npx allure open allure-report"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@wdio/allure-reporter": "^8.40.6",
    "@wdio/cli": "^8.40.6",
    "@wdio/globals": "^8.40.6",
    "@wdio/local-runner": "^8.40.6",
    "@wdio/mocha-framework": "^8.40.6",
    "@wdio/spec-reporter": "^8.40.6",
    "allure-commandline": "^2.38.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2",
    "wdio-video-reporter": "^5.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
